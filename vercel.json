{
  "rewrites": [
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/terms/", "destination": "/terms.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/privacy/", "destination": "/privacy.html" },
    { "source": "/audit", "destination": "/audit.html" },
    { "source": "/audit/", "destination": "/audit.html" },
    { "source": "/api/public-config.js", "destination": "/api/public-config" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/health.js": {
      "maxDuration": 10
    },
    "api/chat/completions.js": {
      "maxDuration": 60
    },
    "api/trend-intelligence.js": {
      "maxDuration": 60
    },
    "api/public-config.js": {
      "maxDuration": 10
    },
    "api/tiktok-live-state.js": {
      "maxDuration": 30
    },
    "api/tiktok-insights.js": {
      "maxDuration": 30
    },
    "api/tiktok-content-approval.js": {
      "maxDuration": 15
    }
  }
}
